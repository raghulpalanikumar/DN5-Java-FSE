Basic PL/SQL Block
DECLARE
   num NUMBER:=10;

BEGIN
   DBMS_OUTPUT.PUT_LINE(num);
END;
/

Output:

10
Variables
DECLARE
   name VARCHAR2(20);
BEGIN
   name:='Raghul';
   DBMS_OUTPUT.PUT_LINE(name);
END;
/
IF Statement
DECLARE
   num NUMBER:=50;

BEGIN
   IF num>40 THEN
      DBMS_OUTPUT.PUT_LINE('Pass');
   END IF;
END;
/
IF ELSE
DECLARE
   num NUMBER:=35;

BEGIN
   IF num>=40 THEN
      DBMS_OUTPUT.PUT_LINE('Pass');
   ELSE
      DBMS_OUTPUT.PUT_LINE('Fail');
   END IF;
END;
/
FOR LOOP
BEGIN
   FOR i IN 1..5 LOOP
      DBMS_OUTPUT.PUT_LINE(i);
   END LOOP;
END;
/

Output

1
2
3
4
5
WHILE LOOP
DECLARE
   i NUMBER:=1;

BEGIN
   WHILE i<=5 LOOP
      DBMS_OUTPUT.PUT_LINE(i);
      i:=i+1;
   END LOOP;
END;
/
Procedure
CREATE OR REPLACE PROCEDURE greet
AS
BEGIN
   DBMS_OUTPUT.PUT_LINE('Hello');
END;
/

Execute:

EXEC greet;
