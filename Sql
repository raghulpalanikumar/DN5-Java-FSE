Exception Handling
DECLARE
   a NUMBER:=10;
   b NUMBER:=0;
   c NUMBER;

BEGIN
   c:=a/b;

EXCEPTION
   WHEN ZERO_DIVIDE THEN
      DBMS_OUTPUT.PUT_LINE('Cannot Divide By Zero');
END;
/
Explicit Cursor
DECLARE

CURSOR c IS
SELECT name
FROM Employee;

v_name Employee.name%TYPE;

BEGIN

OPEN c;

LOOP

FETCH c INTO v_name;

EXIT WHEN c%NOTFOUND;

DBMS_OUTPUT.PUT_LINE(v_name);

END LOOP;

CLOSE c;

END;
/
